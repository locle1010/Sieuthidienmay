@using Web_dienmay.Models
@model IEnumerable<Product>
@{
    int numofquantity = 1;
}

@foreach (var product in Model)
{
    <div class="col product-item">
        <div class="card h-100 shadow-sm hover-shadow border-0">
            <div class="position-relative">
                <!-- Product Category Badge -->
                <span class="position-absolute top-0 start-0 m-2 badge rounded-pill"
                      style="background-color: var(--teal);">
                    @product.Category?.Name
                </span>

                <!-- Stock Status Badge -->
                @if (product.StockQuantity <= 0)
                {
                    <span class="position-absolute top-0 end-0 m-2 badge bg-danger rounded-pill">
                        Hết hàng
                    </span>
                }
                else if (product.StockQuantity <= 5)
                {
                    <span class="position-absolute top-0 end-0 m-2 badge rounded-pill"
                          style="background-color: var(--burnt-orange);">
                        Còn @product.StockQuantity sản phẩm
                    </span>
                }

                <!-- Product Image -->
                <a asp-action="Display" asp-route-id="@product.Id" class="text-decoration-none">
                    <div style="height: 200px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                                 style="width: 100%; height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height: 200px;">
                                <i class="bi bi-image" style="font-size: 3rem; color: var(--teal);"></i>
                            </div>
                        }
                    </div>
                </a>
            </div>

            <div class="card-body d-flex flex-column">
                <!-- Product Name -->
                <a asp-action="Display" asp-route-id="@product.Id" class="text-decoration-none">
                    <h5 class="card-title" style="height: 48px; overflow: hidden; display: -webkit-box;
                                               -webkit-line-clamp: 2; -webkit-box-orient: vertical; color: var(--teal);">
                        @product.Name
                    </h5>
                </a>

                <!-- Product Description -->
                <p class="card-text text-muted" style="height: 72px; overflow: hidden; display: -webkit-box;
                                    -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                    @product.Description
                </p>

                <!-- Đánh giá sao -->
                @if (product.RatingCount > 0)
                {
                    <div class="product-rating mb-2">
                        <div class="rating-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Round(product.AverageRating))
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-warning"></i>
                                }
                            }
                        </div>
                        <small class="text-muted ms-1">(@product.RatingCount)</small>
                    </div>
                }

                <!-- Product Price -->
                <h5 class="card-text mt-auto mb-3" style="color: var(--bright-orange);">@product.Price.ToString("N0") ₫</h5>

                <!-- Add to Cart Button -->
                <div class="d-grid">
                    @if (product.StockQuantity > 0)
                    {
                        <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-id="@product.Id"
                           asp-route-quantity="@numofquantity" class="btn"
                           style="background-color: var(--teal); color: white;">
                            <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                        </a>
                    }
                    else
                    {
                        <button class="btn" style="background-color: var(--dark-gray); color: white;" disabled>
                            <i class="bi bi-cart-plus me-2"></i>Hết hàng
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}
