<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Siêu Thị Điện Máy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebsiteBanHang.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Sticky Navbar Wrapper -->
    <div class="sticky-wrapper">
        <!-- Main Navbar -->
        <nav class="navbar navbar-expand-lg navbar-main" id="mainNavbar">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-lightning-charge-fill me-2 fs-3"></i>
                        <span>SIÊU THỊ ĐIỆN MÁY</span>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <form class="d-flex mx-auto search-form" style="max-width: 400px;" method="get" asp-area="" asp-controller="Product" asp-action="Index">
                        <input class="form-control" type="search" name="searchTerm" placeholder="Tìm kiếm sản phẩm..." aria-label="Search">
                        <button class="btn" type="submit"><i class="bi bi-search"></i></button>
                    </form>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                        <!-- Nút Trang web (dropdown) -->
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="websiteDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-globe me-1"></i> Trang web
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="websiteDropdown">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="About">
                                        <i class="bi bi-info-circle me-2 text-muted"></i>Về chúng tôi
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Privacy">
                                        <i class="bi bi-shield-check me-2 text-muted"></i>Chính sách bảo mật
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Contact">
                                        <i class="bi bi-telephone me-2 text-muted"></i>Liên hệ
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Nút Sản phẩm -->
                        <li class="nav-item me-2">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i> Sản phẩm
                            </a>
                        </li>

                        <!-- Phần đăng nhập -->
                        <partial name="_LoginPartial" />

                        <li class="nav-item ms-2">
                            <a class="nav-link cart-btn-enhanced" asp-area="" asp-controller="ShoppingCart" asp-action="Index">
                                <span class="cart-icon-wrapper">
                                    <i class="bi bi-cart-fill"></i>
                                </span>
                                <span class="cart-text d-none d-lg-inline-block ms-1">Giỏ hàng</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <!-- Placeholder for sticky navbar -->
        <div class="sticky-placeholder"></div>
    </div>

    <!-- Main Content -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Features Bar -->
    <div class="features-bar">
        <div class="container">
            <div class="row">
                <div class="col-md-3 mb-4 mb-md-0">
                    <div class="feature-box">
                        <i class="bi bi-truck"></i>
                        <h5>Giao hàng miễn phí</h5>
                        <p class="text-muted">Cho đơn hàng từ 500.000đ</p>
                    </div>
                </div>
                <div class="col-md-3 mb-4 mb-md-0">
                    <div class="feature-box">
                        <i class="bi bi-shield-check"></i>
                        <h5>Bảo hành chính hãng</h5>
                        <p class="text-muted">Sản phẩm chính hãng 100%</p>
                    </div>
                </div>
                <div class="col-md-3 mb-4 mb-md-0">
                    <div class="feature-box">
                        <i class="bi bi-arrow-repeat"></i>
                        <h5>Đổi trả 30 ngày</h5>
                        <p class="text-muted">Nếu sản phẩm lỗi, hư hỏng</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="feature-box">
                        <i class="bi bi-headset"></i>
                        <h5>Hỗ trợ 24/7</h5>
                        <p class="text-muted">Hotline: 1900 1234</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 mb-4 mb-lg-0">
                    <h5>SIÊU THỊ ĐIỆN MÁY</h5>
                    <p class="mb-4">Hệ thống bán lẻ thiết bị điện tử, điện lạnh, gia dụng hàng đầu Việt Nam</p>
                    <div class="social-icons">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h6>HỖ TRỢ KHÁCH HÀNG</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area ="" asp-controller="Home" asp-action="Privacy">Chính sách thanh toán</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách giao hàng</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách đổi trả</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Chính sách bảo hành</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h6>THÔNG TIN CÔNG TY</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="About">Giới thiệu công ty</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Showroom">Hệ thống showroom</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6>THÔNG TIN LIÊN HỆ</h6>
                    <p class="mb-2"><i class="bi bi-geo-alt me-2"></i>Trụ ngoài, đường giữa, Quận Bình Nguyên Vô Tận, Thành phố Liên Quân</p>
                    <p class="mb-2"><i class="bi bi-telephone me-2"></i>Hotline: 1234 1234</p>
                    <p class="mb-4"><i class="bi bi-envelope me-2"></i>Email: letanlochhgg@gmail.com</p>
                    <div>
                        <img src="http://online.gov.vn/Content/EndUser/LogoCCDVSaleNoti/logoSaleNoti.png" alt="Bộ Công Thương" class="me-2" style="height: 40px;">
                    </div>
                </div>
            </div>

            <hr>

            <div class="row footer-bottom">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">© 2025 Siêu Thị Điện Máy. Tất cả quyền được bảo lưu.</p>
                </div>
                <div class="col-md-6 text-center text-md-end payment-icons">
                    <img src="https://homepage.momocdn.net/fileuploads/svg/momo-file-240411162904.svg" alt="MoMo" class="me-2">
                    <img src="https://simg.zalopay.com.vn/zlp-website/assets/new_logo_6c5db2d21b.svg" alt="ZaloPay" class="me-2">
                    <img src="https://stcd02206177151.cloud.edgevnpay.vn/assets/images/taxi/footer/logo.webp" alt="VNPay" class="me-2">
                    <img src="https://cdn.visa.com/v2/assets/images/logos/visa/blue/logo.png" alt="Visa" class="me-2">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/800px-Mastercard-logo.svg.png" alt="Mastercard">
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const navbar = document.getElementById('mainNavbar');
            const placeholder = document.querySelector('.sticky-placeholder');

            function handleScroll() {
                if (window.scrollY > 0) {
                    navbar.classList.add('navbar-sticky');
                    placeholder.classList.add('active');
                    document.body.classList.add('has-sticky-navbar');
                } else {
                    navbar.classList.remove('navbar-sticky');
                    placeholder.classList.remove('active');
                    document.body.classList.remove('has-sticky-navbar');
                }
            }

            window.addEventListener('scroll', handleScroll);
        });
    </script>

    
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
