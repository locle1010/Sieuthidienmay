@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="container py-5">
    <div class="card border-0 shadow-lg mb-5">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock text-primary" style="font-size: 3rem; color: var(--teal) !important;"></i>
                <h1 class="mt-3" style="color: var(--teal);">Chính sách bảo mật thông tin</h1>
                <p class="text-muted">Cập nhật ngày 17/06/2025</p>
            </div>

            <div class="mb-5">
                <p class="lead" style="color: var(--teal);">
                    Siêu Thị Điện Máy cam kết bảo vệ quyền riêng tư và thông tin cá nhân của khách hàng. Chính sách này mô tả cách chúng tôi thu thập, sử dụng, bảo vệ và chia sẻ thông tin của bạn.
                </p>
            </div>

            <!-- Phần 1: Thông tin thu thập -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">1. Thông tin chúng tôi thu thập</h3>
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="mb-3" style="color: var(--teal);">Thông tin cá nhân</h5>
                        <ul class="text-muted mb-0">
                            <li>Họ tên, địa chỉ email, số điện thoại</li>
                            <li>Địa chỉ giao hàng và thanh toán</li>
                            <li>Thông tin tài khoản đăng nhập</li>
                            <li>Các thông tin cá nhân khác mà bạn cung cấp khi đăng ký tài khoản hoặc thanh toán</li>
                        </ul>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-3" style="color: var(--teal);">Thông tin không cá nhân</h5>
                        <ul class="text-muted mb-0">
                            <li>Thông tin về thiết bị (loại thiết bị, hệ điều hành, trình duyệt)</li>
                            <li>Địa chỉ IP và dữ liệu về vị trí</li>
                            <li>Dữ liệu về hoạt động trên trang web (thời gian truy cập, sản phẩm xem)</li>
                            <li>Cookie và công nghệ theo dõi tương tự</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Phần 2: Mục đích sử dụng thông tin -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">2. Mục đích sử dụng thông tin</h3>

                <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-cart-check me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <h5 class="mb-0" style="color: var(--teal);">Xử lý đơn hàng</h5>
                                </div>
                                <p class="text-muted mb-0">Xử lý và giao các đơn hàng, thông báo về trạng thái đơn hàng, cung cấp dịch vụ chăm sóc khách hàng.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-person-check me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <h5 class="mb-0" style="color: var(--teal);">Quản lý tài khoản</h5>
                                </div>
                                <p class="text-muted mb-0">Tạo và quản lý tài khoản của bạn, xác thực người dùng, và cung cấp quyền truy cập vào các dịch vụ của chúng tôi.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-megaphone me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <h5 class="mb-0" style="color: var(--teal);">Tiếp thị và quảng cáo</h5>
                                </div>
                                <p class="text-muted mb-0">Gửi thông báo về sản phẩm, khuyến mãi, và tin tức mới. Bạn có thể hủy đăng ký nhận thông báo bất kỳ lúc nào.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-graph-up me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <h5 class="mb-0" style="color: var(--teal);">Cải thiện dịch vụ</h5>
                                </div>
                                <p class="text-muted mb-0">Phân tích dữ liệu để cải thiện trang web, sản phẩm và dịch vụ, phát triển tính năng mới, và hiểu hành vi của người dùng.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phần 3: Bảo vệ thông tin -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">3. Bảo vệ thông tin của bạn</h3>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <p class="text-muted">Chúng tôi thực hiện các biện pháp bảo mật thích hợp để bảo vệ thông tin cá nhân của bạn trước các truy cập trái phép, thay đổi, tiết lộ hoặc phá hủy. Các biện pháp này bao gồm:</p>

                        <div class="row mt-4">
                            <div class="col-md-6 mb-4">
                                <div class="d-flex">
                                    <i class="bi bi-lock-fill me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Mã hóa dữ liệu</h5>
                                        <p class="text-muted mb-0">Sử dụng công nghệ mã hóa SSL để bảo vệ dữ liệu trong quá trình truyền tải.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="d-flex">
                                    <i class="bi bi-shield-check me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Hệ thống bảo mật</h5>
                                        <p class="text-muted mb-0">Áp dụng các hệ thống bảo mật tiên tiến để ngăn chặn truy cập trái phép.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="d-flex">
                                    <i class="bi bi-person-lock me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Kiểm soát truy cập</h5>
                                        <p class="text-muted mb-0">Giới hạn quyền truy cập vào thông tin cá nhân chỉ cho nhân viên có nhu cầu công việc.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-arrow-repeat me-3" style="font-size: 1.5rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Cập nhật thường xuyên</h5>
                                        <p class="text-muted mb-0">Thường xuyên cập nhật các biện pháp bảo mật để đối phó với các mối đe dọa mới.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phần 4: Chia sẻ thông tin -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">4. Chia sẻ thông tin</h3>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-4">Chúng tôi không bán, trao đổi, hoặc chuyển giao thông tin cá nhân của bạn cho bên thứ ba mà không có sự đồng ý của bạn, ngoại trừ:</p>

                        <div class="d-flex mb-3">
                            <i class="bi bi-truck me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0"><strong>Đối tác dịch vụ:</strong> Công ty vận chuyển để giao hàng, công ty thanh toán để xử lý giao dịch.</p>
                        </div>

                        <div class="d-flex mb-3">
                            <i class="bi bi-bar-chart me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0"><strong>Phân tích dữ liệu:</strong> Đối tác phân tích giúp chúng tôi hiểu cách khách hàng sử dụng dịch vụ.</p>
                        </div>

                        <div class="d-flex mb-3">
                            <i class="bi bi-building me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0"><strong>Đối tác kinh doanh:</strong> Các đối tác kinh doanh được chọn lọc để cung cấp dịch vụ liên quan.</p>
                        </div>

                        <div class="d-flex">
                            <i class="bi bi-bank me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0"><strong>Yêu cầu pháp lý:</strong> Khi chúng tôi bị yêu cầu bởi pháp luật hoặc để bảo vệ quyền lợi của chúng tôi.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phần 5: Quyền của người dùng -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">5. Quyền của bạn</h3>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-4">Theo pháp luật Việt Nam và cam kết của chúng tôi, bạn có các quyền sau đối với thông tin cá nhân của mình:</p>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-eye me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Quyền truy cập</h5>
                                        <p class="text-muted mb-0">Bạn có thể yêu cầu xem thông tin cá nhân mà chúng tôi lưu trữ về bạn.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-pencil-square me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Quyền chỉnh sửa</h5>
                                        <p class="text-muted mb-0">Bạn có thể yêu cầu cập nhật hoặc sửa đổi thông tin không chính xác.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-trash me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Quyền xóa</h5>
                                        <p class="text-muted mb-0">Bạn có thể yêu cầu xóa thông tin cá nhân của mình trong một số trường hợp.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex">
                                    <i class="bi bi-x-circle me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                                    <div>
                                        <h5 style="color: var(--teal);">Quyền từ chối</h5>
                                        <p class="text-muted mb-0">Bạn có thể từ chối việc xử lý thông tin cá nhân trong một số trường hợp.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phần 6: Cookie và công nghệ tương tự -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">6. Cookie và công nghệ tương tự</h3>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="text-muted">Chúng tôi sử dụng cookie và các công nghệ tương tự để cải thiện trải nghiệm của bạn trên trang web của chúng tôi. Cookie là các tệp nhỏ được lưu trữ trên thiết bị của bạn để ghi nhớ thông tin về hoạt động duyệt web.</p>

                        <div class="mt-4">
                            <h5 style="color: var(--teal);">Các loại cookie chúng tôi sử dụng:</h5>
                            <ul class="text-muted">
                                <li><strong>Cookie cần thiết:</strong> Cần thiết để trang web hoạt động và không thể tắt.</li>
                                <li><strong>Cookie phân tích:</strong> Giúp chúng tôi hiểu cách khách hàng tương tác với trang web.</li>
                                <li><strong>Cookie chức năng:</strong> Cho phép trang web nhớ các lựa chọn của bạn.</li>
                                <li><strong>Cookie tiếp thị:</strong> Được sử dụng để theo dõi người dùng trên các trang web.</li>
                            </ul>

                            <p class="text-muted mt-3">Bạn có thể kiểm soát cookie bằng cách điều chỉnh cài đặt trình duyệt. Tuy nhiên, việc tắt một số cookie có thể ảnh hưởng đến trải nghiệm của bạn trên trang web.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phần 7: Thay đổi chính sách -->
            <div class="mb-5">
                <h3 class="mb-4" style="color: var(--teal);">7. Thay đổi chính sách bảo mật</h3>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="text-muted">Chúng tôi có thể cập nhật chính sách bảo mật này theo thời gian để phản ánh những thay đổi trong hoạt động kinh doanh hoặc để tuân thủ các yêu cầu pháp lý. Mọi thay đổi sẽ được đăng trên trang này với ngày cập nhật mới.</p>

                        <p class="text-muted">Chúng tôi khuyến khích bạn kiểm tra trang này định kỳ để biết thông tin mới nhất về cách chúng tôi bảo vệ thông tin cá nhân của bạn.</p>
                    </div>
                </div>
            </div>

            <!-- Phần 8: Liên hệ -->
            <div>
                <h3 class="mb-4" style="color: var(--teal);">8. Liên hệ với chúng tôi</h3>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="text-muted mb-4">Nếu bạn có bất kỳ câu hỏi nào về chính sách bảo mật này hoặc cách chúng tôi xử lý thông tin của bạn, vui lòng liên hệ với chúng tôi:</p>

                        <div class="d-flex mb-3">
                            <i class="bi bi-building me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0"><strong>Siêu Thị Điện Máy</strong></p>
                        </div>

                        <div class="d-flex mb-3">
                            <i class="bi bi-geo-alt me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0">Số 31 Ung Văn Khiêm, P.25, Q.Bình Thạnh, TP.HCM</p>
                        </div>

                        <div class="d-flex mb-3">
                            <i class="bi bi-envelope me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0">privacy@dienmay.com</p>
                        </div>

                        <div class="d-flex">
                            <i class="bi bi-telephone me-3" style="font-size: 1.25rem; color: var(--bright-orange);"></i>
                            <p class="text-muted mb-0">1900 1234</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
</style>
