@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<div class="container py-5">
    <!-- Hero Section -->
    <div class="card border-0 shadow-lg mb-5 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-6">
                <div class="card-body p-4 p-md-5 d-flex flex-column h-100 justify-content-center">
                    <h1 class="display-5 fw-bold mb-4" style="color: var(--teal);">Về Chúng Tôi</h1>
                    <p class="lead mb-4">
                        Chào mừng bạn đến với cửa hàng điện máy của chúng tôi - nơi cung cấp các sản phẩm điện máy
                        chất lượng cao với dịch vụ tận tâm và giá cả hợp lý.
                    </p>
                    <p class="mb-0">
                        Được thành lập vào năm 2020, chúng tôi tự hào là đối tác tin cậy cung cấp các sản phẩm điện máy
                        hàng đầu từ các thương hiệu nổi tiếng trên thế giới.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div style="height: 400px; background: linear-gradient(135deg, var(--teal) 0%, #005a70 100%); overflow: hidden;">
                    <div class="d-flex align-items-center justify-content-center h-100">
                        <i class="bi bi-buildings text-white" style="font-size: 8rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Our Mission -->
    <div class="row mb-5">
        <div class="col-lg-4 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-bullseye" style="font-size: 3rem; color: var(--bright-orange);"></i>
                    <h3 class="mt-4 mb-3" style="color: var(--teal);">Sứ Mệnh</h3>
                    <p class="mb-0">
                        Cung cấp các sản phẩm điện máy chất lượng cao với giá cả phải chăng,
                        kèm theo dịch vụ hỗ trợ khách hàng tận tâm và chuyên nghiệp.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-eye" style="font-size: 3rem; color: var(--bright-orange);"></i>
                    <h3 class="mt-4 mb-3" style="color: var(--teal);">Tầm Nhìn</h3>
                    <p class="mb-0">
                        Trở thành điểm đến hàng đầu về điện máy tại Việt Nam,
                        được khách hàng tin tưởng và lựa chọn nhờ chất lượng và dịch vụ vượt trội.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-award" style="font-size: 3rem; color: var(--bright-orange);"></i>
                    <h3 class="mt-4 mb-3" style="color: var(--teal);">Giá Trị Cốt Lõi</h3>
                    <p class="mb-0">
                        Chất lượng - Uy tín - Tận tâm - Đổi mới.
                        Chúng tôi cam kết đặt lợi ích và trải nghiệm của khách hàng lên hàng đầu.
                    </p>
                </div>
            </div>
        </div>
    </div>

