@using Web_dienmay.Models
@model ShoppingCart
@inject Web_dienmay.Repositories.IProductRepository ProductRepository

@{
    bool hasOutOfStockItems = false;
    var productStockStatus = new Dictionary<int, (bool isAvailable, int stockQuantity)>();
    
    if (Model.Items != null && Model.Items.Any())
    {
        foreach (var item in Model.Items)
        {
            var product = await ProductRepository.GetByIdAsync(item.ProductId);
            productStockStatus[item.ProductId] = (
                product?.IsAvailable ?? false, 
                product?.StockQuantity ?? 0
            );
            
            if (product == null || !product.IsAvailable || product.StockQuantity < item.Quantity)
            {
                hasOutOfStockItems = true;
            }
        }
    }
}

<div class="main-content container py-4">
    <h2 class="mb-4 text-center" style="color: var(--teal);">Giỏ hàng của bạn</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert mb-4" style="background-color: var(--cream); color: var(--teal); border-color: var(--teal);">
            <i class="bi bi-check-circle-fill me-2" style="color: var(--teal);"></i>
            @TempData["Success"]
        </div>
    }

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="alert mb-4" style="background-color: var(--cream); color: var(--teal);">
            <i class="bi bi-cart-x fs-1 d-block mb-3" style="color: var(--teal);"></i>
            <h4>Giỏ hàng của bạn đang trống</h4>
            <p>Hãy thêm sản phẩm vào giỏ hàng để tiếp tục.</p>
            <a asp-controller="Product" asp-action="Index" class="btn mt-2" style="background-color: var(--teal); color: white;">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        @if (hasOutOfStockItems)
        {
            <div class="alert mb-4" style="background-color: var(--cream); color: var(--burnt-orange); border-color: var(--burnt-orange);">
                <i class="bi bi-exclamation-triangle-fill me-2" style="color: var(--burnt-orange);"></i>
                <strong>Lưu ý:</strong> Một số sản phẩm trong giỏ hàng đã hết hàng hoặc không đủ số lượng.
                Vui lòng xóa hoặc điều chỉnh số lượng trước khi thanh toán.
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead style="background-color: var(--cream);">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                bool isOutOfStock = !productStockStatus[item.ProductId].isAvailable || 
                                                   productStockStatus[item.ProductId].stockQuantity < item.Quantity;
                                int stockAvailable = productStockStatus[item.ProductId].stockQuantity;
                                
                                <tr class="@(isOutOfStock ? "table-danger" : "")">
                                    <td class="align-middle">
                                        <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@item.ProductId" class="text-decoration-none">
                                            <span style="color: var(--teal);">@item.Name</span>
                                        </a>
                                        @if (isOutOfStock)
                                        {
                                            <div class="text-danger small">
                                                @if (!productStockStatus[item.ProductId].isAvailable)
                                                {
                                                    <span><i class="bi bi-exclamation-circle me-1"></i>Sản phẩm đã ngừng kinh doanh</span>
                                                }
                                                else if (productStockStatus[item.ProductId].stockQuantity == 0)
                                                {
                                                    <span><i class="bi bi-exclamation-circle me-1"></i>Sản phẩm đã hết hàng</span>
                                                }
                                                else
                                                {
                                                    <span><i class="bi bi-exclamation-circle me-1"></i>Chỉ còn @stockAvailable sản phẩm</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="d-flex justify-content-center align-items-center">
                                            <a asp-action="DecreaseQuantity" asp-route-Id="@item.ProductId"
                                               class="btn btn-sm me-2" style="border-color: var(--teal); color: var(--teal);">-</a>
                                            <span>@item.Quantity</span>
                                            @if (isOutOfStock)
                                            {
                                                <a class="btn btn-sm ms-2 disabled" style="border-color: var(--dark-gray); color: var(--dark-gray);">+</a>
                                            }
                                            else
                                            {
                                                <a asp-action="IncreaseQuantity" asp-route-Id="@item.ProductId"
                                                   class="btn btn-sm ms-2" style="border-color: var(--teal); color: var(--teal);">+</a>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end align-middle" style="color: var(--bright-orange);">@item.Price.ToString("N0") ₫</td>
                                    <td class="text-end align-middle" style="color: var(--bright-orange); font-weight: bold;">@((item.Price * item.Quantity).ToString("N0")) ₫</td>
                                    <td class="text-center align-middle">
                                        <a asp-action="RemoveFromCart" asp-route-Id="@item.ProductId"
                                           class="btn btn-sm" style="border-color: var(--bright-orange); color: var(--bright-orange);">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: var(--cream);">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end fw-bold" style="color: var(--bright-orange);">
                                    @Model.Items.Sum(i => i.Price * i.Quantity).ToString("N0") ₫
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a asp-controller="Product" asp-action="Index" class="btn" style="border-color: var(--teal); color: var(--teal);">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
            
            @if (hasOutOfStockItems)
            {
                <button class="btn" disabled style="background-color: var(--dark-gray); color: white;">
                    <i class="bi bi-credit-card me-2"></i>Thanh toán
                </button>
            }
            else
            {
                <a asp-action="Checkout" class="btn" style="background-color: var(--teal); color: white;">
                    <i class="bi bi-credit-card me-2"></i>Thanh toán
                </a>
            }
        </div>
    }
</div>
