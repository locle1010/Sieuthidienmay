<!-- WebsiteBanHang/Views/Order/Invoice.cshtml -->
@model Web_dienmay.Models.Order

@{
    ViewData["Title"] = "Hóa đơn #" + Model.Id;
    var invoiceHtml = ViewBag.InvoiceHtml;
}

<div class="main-content container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: var(--teal);">Hóa đơn #@Model.Id</h2>
        <div>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn me-2"
               style="border-color: var(--teal); color: var(--teal);">
                <i class="bi bi-arrow-left me-2"></i>Quay lại
            </a>
            <a asp-action="DownloadInvoice" asp-route-id="@Model.Id" class="btn me-2"
               style="background-color: var(--teal); color: white;">
                <i class="bi bi-download me-2"></i>Tải về PDF
            </a>
            @* <button onclick="printInvoice()" class="btn" *@
            @*         style="background-color: var(--bright-orange); color: white;"> *@
            @*     <i class="bi bi-printer me-2"></i>In hóa đơn *@
            @* </button> *@
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header" style="background-color: var(--cream);">
            <h5 class="mb-0" style="color: var(--teal);">Chi tiết hóa đơn</h5>
        </div>
        <div class="card-body p-0">
            <div id="invoice-content">
                @Html.Raw(invoiceHtml)
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function printInvoice() {
            const printContent = document.getElementById('invoice-content').innerHTML;
            const originalContent = document.body.innerHTML;

            document.body.innerHTML = printContent;
            window.print();
            document.body.innerHTML = originalContent;

            // Reload scripts after printing
            location.reload();
        }
    </script>
}

