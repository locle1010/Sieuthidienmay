@page
@using Web_dienmay.Areas.Identity.Pages.Account.Manage
@model IndexModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="mb-4 fw-bold" style="color: #1e293b;">
    <i class="bi bi-person-circle me-2" style="color: #83a4d4;"></i>@ViewData["Title"]
</h3>

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-modern border-0 rounded-4">
            <div class="card-body p-4">
                <form id="profile-form" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                    }
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" disabled />
                        <label asp-for="Username"><i class="bi bi-person me-2"></i>Tên đăng nhập</label>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                        <label asp-for="Input.PhoneNumber"><i class="bi bi-telephone me-2"></i>Số điện thoại</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>
                    
                    <button id="update-profile-button" type="submit" class="btn btn-primary px-4 py-2 fw-bold">
                        <i class="bi bi-save me-2"></i>Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <partial name="_ValidationScriptsPartial" />
    <style>
        .form-floating > .form-control:focus ~ label {
            color: #83a4d4;
        }
        
        .form-control:focus {
            border-color: #83a4d4;
            box-shadow: 0 0 0 0.2rem rgba(131, 164, 212, 0.15);
        }
        
        /* Ẩn validation summary khi không có lỗi */
        .validation-summary-valid {
            display: none !important;
        }
    </style>
}
