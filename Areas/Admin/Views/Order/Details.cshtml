@using Web_dienmay.Models
@model Order
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<div class="container-fluid">
    <h1 class="mt-4">Chi tiết đơn hàng #@Model.Id</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Order" asp-action="Index">Quản lý đơn hàng</a></li>
        <li class="breadcrumb-item active">Chi tiết đơn hàng #@Model.Id</li>
    </ol>

    <div class="row mb-4">
        <div class="col-12 mb-3">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="m-0">Thông tin đơn hàng</h5>
                    <div>
                        <a asp-action="Invoice" asp-route-id="@Model.Id" class="btn btn-info">
                            <i class="bi bi-file-earmark-text me-2"></i>Xem hóa đơn
                        </a>
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại danh sách
                        </a>
                        
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong>Mã đơn hàng:</strong> #@Model.Id
                            </div>
                            <div class="mb-3">
                                <strong>Ngày đặt hàng:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </div>
                            <div class="mb-3">
                                <strong>Tổng giá trị:</strong> @Model.TotalPrice.ToString("N0") ₫
                            </div>
                            <div class="mb-3">
                                <strong>Trạng thái:</strong>
                                @{
                                    var badgeClass = Model.OrderStatus switch
                                    {
                                        "Đang xử lý" => "bg-warning",
                                        "Đã xác nhận" => "bg-info",
                                        "Đang giao hàng" => "bg-primary",
                                        "Đã giao hàng" => "bg-success",
                                        "Đã hủy" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@Model.OrderStatus</span>
                            </div>
                            @if (Model.ShippedDate.HasValue)
                            {
                                <div class="mb-3">
                                    <strong>Ngày giao hàng:</strong> @Model.ShippedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong>Khách hàng:</strong> @Model.ApplicationUser.FullName
                            </div>
                            <div class="mb-3">
                                <strong>Email:</strong> @Model.ApplicationUser.Email
                            </div>
                            <div class="mb-3">
                                <strong>Địa chỉ giao hàng:</strong>
                                <p class="mb-0">@Model.ShippingAddress</p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="mb-3">
                                    <strong>Ghi chú:</strong>
                                    <p class="mb-0">@Model.Notes</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <h5>Cập nhật trạng thái đơn hàng</h5>
                        <form asp-action="UpdateStatus" method="post" class="row g-3">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="col-md-6">
                                <select name="status" class="form-select">
                                    <option value="Đang xử lý" selected="@(Model.OrderStatus == "Đang xử lý")">Đang xử lý</option>
                                    <option value="Đã xác nhận" selected="@(Model.OrderStatus == "Đã xác nhận")">Đã xác nhận</option>
                                    <option value="Đang giao hàng" selected="@(Model.OrderStatus == "Đang giao hàng")">Đang giao hàng</option>
                                    <option value="Đã giao hàng" selected="@(Model.OrderStatus == "Đã giao hàng")">Đã giao hàng</option>
                                    <option value="Đã hủy" selected="@(Model.OrderStatus == "Đã hủy")">Đã hủy</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-primary">Cập nhật trạng thái</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="m-0">Chi tiết sản phẩm</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td class="align-middle">
                                    @if (item.Product != null)
                                    {
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name"
                                                     style="width: 50px; height: 50px; object-fit: cover;" class="me-3">
                                            }
                                            <div>
                                                <a asp-area="" asp-controller="Product" asp-action="Display"
                                                   asp-route-id="@item.ProductId" class="text-decoration-none">
                                                    @item.Product.Name
                                                </a>
                                                <small class="text-muted d-block">Mã: #@item.ProductId</small>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>Sản phẩm #@item.ProductId</span>
                                    }
                                </td>
                                <td class="text-center align-middle">@item.Quantity</td>
                                <td class="text-end align-middle">@item.Price.ToString("N0") ₫</td>
                                <td class="text-end align-middle">@((item.Price * item.Quantity).ToString("N0")) ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold">
                                @Model.TotalPrice.ToString("N0") ₫
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
