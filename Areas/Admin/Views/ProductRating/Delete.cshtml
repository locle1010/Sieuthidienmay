@* WebsiteBanHang/Areas/Admin/Views/ProductRating/Delete.cshtml *@
@model ProductRating
@{
    ViewData["Title"] = "Xóa đánh giá";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Xóa đánh giá</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="ProductRating" asp-action="Index">Đánh giá sản phẩm</a></li>
        <li class="breadcrumb-item active">Xóa đánh giá #@Model.Id</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-exclamation-triangle me-1"></i>
            Xác nhận xóa đánh giá
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h4 class="alert-heading">Cảnh báo!</h4>
                <p>Bạn có chắc chắn muốn xóa đánh giá này không? Hành động này không thể hoàn tác.</p>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Thông tin đánh giá</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-2"><strong>ID đánh giá:</strong> @Model.Id</p>
                            <p class="mb-2"><strong>Sản phẩm:</strong> @Model.Product.Name (ID: @Model.Product.Id)</p>
                            <p class="mb-2"><strong>Người dùng:</strong> @Model.User.FullName (@Model.User.Email)</p>
                            <p class="mb-2"><strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</p>
                            <p class="mb-2">
                                <strong>Điểm đánh giá:</strong>
                                <span class="ms-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Model.Rating)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                    <span class="ms-2">(@Model.Rating/5)</span>
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Bình luận</h6>
                                </div>
                                <div class="card-body">
                                    @if (string.IsNullOrEmpty(Model.Comment))
                                    {
                                        <p class="text-muted mb-0">Người dùng không để lại bình luận.</p>
                                    }
                                    else
                                    {
                                        <p class="mb-0">@Model.Comment</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <form method="post">
                <input type="hidden" asp-for="Id" />
                @if (Context.Request.Query.ContainsKey("returnToProduct"))
                {
                    <input type="hidden" name="returnToProduct" value="true" />
                }
                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xóa đánh giá
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
