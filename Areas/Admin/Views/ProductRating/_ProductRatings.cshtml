@* WebsiteBanHang/Areas/Admin/Views/ProductRating/_ProductRatings.cshtml *@
@model IEnumerable<ProductRating>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-star me-1"></i> Đánh giá sản phẩm</span>
        <a asp-area="Admin" asp-controller="ProductRating" asp-action="Index"
           asp-route-productId="@(Model.FirstOrDefault()?.ProductId)" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-list"></i> Xem tất cả đánh giá
        </a>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">Sản phẩm này chưa có đánh giá nào.</p>
        }
        else
        {
            <div class="d-flex align-items-center mb-3">
                <h4 class="mb-0 me-2">@Model.Average(r => r.Rating).ToString("0.0")</h4>
                <div class="rating-display me-2">
                    @{
                        var avgRating = Model.Average(r => r.Rating);
                        for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(avgRating))
                            {
                                <i class="bi bi-star-fill text-warning"></i>
                            }
                            else if (i <= Math.Ceiling(avgRating) && i > Math.Floor(avgRating))
                            {
                                <i class="bi bi-star-half text-warning"></i>
                            }
                            else
                            {
                                <i class="bi bi-star text-warning"></i>
                            }
                        }
                    }
                </div>
                <span class="text-muted">(@Model.Count() đánh giá)</span>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Người dùng</th>
                            <th>Đánh giá</th>
                            <th>Bình luận</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rating in Model.Take(5)) // Only show first 5 ratings
                        {
                            <tr>
                                <td>@rating.User.FullName</td>
                                <td>
                                    <div class="rating-display">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= rating.Rating)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star text-warning"></i>
                                            }
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(rating.Comment))
                                    {
                                        <span class="text-muted">Không có bình luận</span>
                                    }
                                    else
                                    {
                                        @(rating.Comment.Length > 30 ? rating.Comment.Substring(0, 30) + "..." : rating.Comment)
                                    }
                                </td>
                                <td>@rating.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a asp-area="Admin" asp-controller="ProductRating" asp-action="Details"
                                       asp-route-id="@rating.Id" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="ProductRating" asp-action="Delete"
                                       asp-route-id="@rating.Id" asp-route-returnToProduct="true" class="btn btn-sm btn-danger ms-1">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Count() > 5)
            {
                <div class="text-center mt-2">
                    <a asp-area="Admin" asp-controller="ProductRating" asp-action="Index"
                       asp-route-productId="@(Model.FirstOrDefault()?.ProductId)" class="btn btn-sm btn-outline-primary">
                        Xem tất cả @Model.Count() đánh giá
                    </a>
                </div>
            }
        }
    </div>
</div>
