@model IEnumerable<Web_dienmay.Models.StockEntry>

@{
    ViewData["Title"] = "Lịch sử nhập xuất kho";
    var selectedProductId = ViewBag.SelectedProductId as int?;
    var selectedType = ViewBag.SelectedType as string;
    var fromDate = ViewBag.FromDate as string;
    var toDate = ViewBag.ToDate as string;
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2 class="text-black"><i class="bi bi-box-seam"></i> Lịch sử nhập xuất kho</h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Import" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Nhập kho
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @Html.Raw(TempData["Success"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @Html.Raw(TempData["Error"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Sản phẩm</label>
                        <select name="productId" class="form-select">
                            <option value="">Tất cả sản phẩm</option>
                            @foreach (var product in ViewBag.Products)
                            {
                                <option value="@product.Id" selected="@(product.Id == selectedProductId)">
                                    @product.Name
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Loại giao dịch</label>
                        <select name="type" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Import" selected="@(selectedType == "Import")">Nhập kho</option>
                            <option value="Export" selected="@(selectedType == "Export")">Xuất kho</option>
                            <option value="Adjustment" selected="@(selectedType == "Adjustment")">Điều chỉnh</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" name="fromDate" class="form-control" value="@fromDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" name="toDate" class="form-control" value="@toDate">
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Lọc
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Bảng lịch sử -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 5%;">ID</th>
                            <th style="width: 20%;">Sản phẩm</th>
                            <th style="width: 10%;" class="text-center">Loại</th>
                            <th style="width: 8%;" class="text-center">Số lượng</th>
                            <th style="width: 8%;" class="text-center">Trước</th>
                            <th style="width: 8%;" class="text-center">Sau</th>
                            <th style="width: 20%;">Ghi chú</th>
                            <th style="width: 12%;">Người thực hiện</th>
                            <th style="width: 12%;">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var entry in Model)
                            {
                                <tr>
                                    <td>@entry.Id</td>
                                    <td>
                                        <strong>@entry.Product?.Name</strong>
                                        <br />
                                        <small class="text-muted">@entry.Product?.Category?.Name</small>
                                    </td>
                                    <td class="text-center">
                                        @if (entry.Type == "Import")
                                        {
                                            <span class="badge bg-success">Nhập kho</span>
                                        }
                                        else if (entry.Type == "Export")
                                        {
                                            <span class="badge bg-danger">Xuất kho</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Điều chỉnh</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (entry.Quantity > 0)
                                        {
                                            <span class="text-success fw-bold">+@entry.Quantity</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">@entry.Quantity</span>
                                        }
                                    </td>
                                    <td class="text-center">@entry.PreviousQuantity</td>
                                    <td class="text-center"><strong>@entry.NewQuantity</strong></td>
                                    <td>@(entry.Note ?? "-")</td>
                                    <td>@entry.CreatedBy</td>
                                    <td>
                                        @entry.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    Không có dữ liệu lịch sử nhập xuất kho
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>