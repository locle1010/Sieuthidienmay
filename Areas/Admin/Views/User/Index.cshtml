<!-- WebsiteBanHang/Areas/Admin/Views/User/Index.cshtml -->
@model List<Web_dienmay.ViewModels.UserRolesViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2 class="text-black">Quản lý người dùng</h2>
        </div>
        <div class="col-md-4">
            <div class="d-flex justify-content-end">
                <a asp-area="Admin" asp-controller="User" asp-action="Create" class="btn btn-success">
                    <i class="bi bi-person-plus me-2"></i>Tạo tài khoản mới
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Tên đầy đủ</th>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.UserName</td>
                                <td>@user.Email</td>
                                <td>
                                    @string.Join(", ", user.Roles)
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-area="Admin" asp-controller="User" asp-action="Details" asp-route-userId="@user.UserId" class="btn btn-info btn-sm">
                                            <i class="bi bi-info-circle"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="User" asp-action="Manage" asp-route-userId="@user.UserId" class="btn btn-primary btn-sm">
                                            <i class="bi bi-person-gear"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="User" asp-action="Delete" asp-route-userId="@user.UserId" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
