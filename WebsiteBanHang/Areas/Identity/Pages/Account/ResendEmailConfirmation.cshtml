@page
@using Web_dienmay.Areas.Identity.Pages.Account
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Gửi lại email xác nhận";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-modern-lg border-0 rounded-4">
                <div class="card-header text-center py-4"
                     style="background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%); border-bottom: 2px solid #e0f2fe;">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center"
                             style="width: 70px; height: 70px; background: linear-gradient(135deg, #4fc3f7 0%, #81d4fa 100%); border-radius: 50%; box-shadow: 0 8px 20px rgba(79, 195, 247, 0.35);">
                            <i class="bi bi-envelope-check" style="color: white; font-size: 2rem;"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-0" style="color: #1e293b;">GỬI LẠI EMAIL XÁC NHẬN</h3>
                    <p class="text-muted mb-0 mt-2">Nhận email xác nhận mới</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-3" role="alert"></div>

                        <div class="alert alert-info rounded-3 mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Nhập địa chỉ email đã đăng ký để nhận lại email xác nhận.
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control" aria-required="true"
                                   placeholder="name@example.com" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 mb-4 fw-bold">
                            <i class="bi bi-send me-2"></i>Gửi email xác nhận
                        </button>

                        <div class="text-center">
                            <a class="text-decoration-none d-block py-2 rounded-3 hover-link" asp-page="./Login">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <partial name="_ValidationScriptsPartial" />
    <style>
        body {
            background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
            min-height: 100vh;
        }

        .form-floating > .form-control:focus ~ label {
            color: #83a4d4;
        }

        .form-control:focus {
            border-color: #83a4d4;
            box-shadow: 0 0 0 0.2rem rgba(131, 164, 212, 0.15);
        }

        .hover-link {
            color: #64748b;
            transition: all 0.3s ease;
        }

        .hover-link:hover {
            color: #83a4d4;
            background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
            transform: translateX(5px);
        }
    </style>
}
