@page
@using Web_dienmay.Areas.Identity.Pages.Account
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Xác nhận đặt lại mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-modern-lg border-0 rounded-4">
                <div class="card-header text-center py-4" style="background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%); border-bottom: 2px solid #e0f2fe;">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center" 
                             style="width: 70px; height: 70px; background: linear-gradient(135deg, #26c6da 0%, #4dd0e1 100%); border-radius: 50%; box-shadow: 0 8px 20px rgba(38, 198, 218, 0.35);">
                            <i class="bi bi-check-circle" style="color: white; font-size: 2.5rem;"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-0" style="color: #1e293b;">THÀNH CÔNG!</h3>
                </div>
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="alert alert-success rounded-3 mb-4">
                        <i class="bi bi-shield-check me-2"></i>
                        Mật khẩu của bạn đã được đặt lại thành công.
                    </div>
                    
                    <p class="text-muted mb-4">
                        Bạn có thể đăng nhập với mật khẩu mới của mình.
                    </p>
                    
                    <a asp-page="./Login" class="btn btn-primary w-100 py-3 fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
            min-height: 100vh;
        }
    </style>
}
