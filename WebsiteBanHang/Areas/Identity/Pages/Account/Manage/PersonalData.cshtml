@page
@using Web_dienmay.Areas.Identity.Pages.Account.Manage
@model PersonalDataModel
@{
    ViewData["Title"] = "Dữ liệu cá nhân";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="mb-4 fw-bold" style="color: #1e293b;">
    <i class="bi bi-file-person me-2" style="color: #83a4d4;"></i>@ViewData["Title"]
</h3>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-modern border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="alert alert-info rounded-3 mb-4">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Quản lý dữ liệu cá nhân</strong>
                    <p class="mb-0 mt-2">
                        Tài khoản của bạn chứa dữ liệu cá nhân mà bạn đã cung cấp cho chúng tôi. 
                        Trang này cho phép bạn tải xuống hoặc xóa dữ liệu đó.
                    </p>
                </div>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card border-primary" style="border-width: 2px !important; border-radius: 12px;">
                            <div class="card-body text-center p-4">
                                <i class="bi bi-download" style="font-size: 3rem; color: #83a4d4;"></i>
                                <h5 class="mt-3 mb-3 fw-bold">Tải xuống dữ liệu</h5>
                                <p class="text-muted small mb-4">
                                    Tải xuống tất cả dữ liệu cá nhân của bạn dưới dạng file JSON
                                </p>
                                <form id="download-data" asp-page="DownloadPersonalData" method="post">
                                    <button class="btn btn-primary w-100 py-2 fw-bold" type="submit">
                                        <i class="bi bi-download me-2"></i>Tải xuống
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="card border-danger" style="border-width: 2px !important; border-radius: 12px;">
                            <div class="card-body text-center p-4">
                                <i class="bi bi-trash" style="font-size: 3rem; color: #ef4444;"></i>
                                <h5 class="mt-3 mb-3 fw-bold">Xóa dữ liệu</h5>
                                <p class="text-muted small mb-4">
                                    Xóa vĩnh viễn tài khoản và tất cả dữ liệu của bạn
                                </p>
                                <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger w-100 py-2 fw-bold">
                                    <i class="bi bi-trash me-2"></i>Xóa tài khoản
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-warning rounded-3 mt-4 mb-0">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Cảnh báo quan trọng:</strong>
                            <p class="mb-0 small mt-1">
                                Việc xóa dữ liệu này sẽ xóa vĩnh viễn tài khoản của bạn và không thể khôi phục được. 
                                Hãy chắc chắn rằng bạn đã tải xuống mọi dữ liệu quan trọng trước khi xóa.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <partial name="_ValidationScriptsPartial" />
}
