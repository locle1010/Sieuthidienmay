@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Web_dienmay.Areas.Identity.Pages.Account.Manage
@using Web_dienmay.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="card shadow-modern border-0 rounded-4 mb-4">
    <div class="card-header py-3" style="background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%); border-bottom: 2px solid #e0f2fe;">
        <h5 class="mb-0 fw-bold" style="color: #1e293b;">
            <i class="bi bi-gear me-2" style="color: #83a4d4;"></i>Cài đặt tài khoản
        </h5>
    </div>
    <div class="card-body p-0">
        <ul class="nav nav-pills flex-column">
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext) px-4 py-3" id="profile" asp-page="./Index">
                    <i class="bi bi-person-circle me-2"></i>Thông tin cá nhân
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext) px-4 py-3" id="email" asp-page="./Email">
                    <i class="bi bi-envelope me-2"></i>Email
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext) px-4 py-3" id="change-password" asp-page="./ChangePassword">
                    <i class="bi bi-key me-2"></i>Đổi mật khẩu
                </a>
            </li>
            @if (hasExternalLogins)
            {
                <li class="nav-item">
                    <a class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext) px-4 py-3" id="external-login" asp-page="./ExternalLogins">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập bên ngoài
                    </a>
                </li>
            }
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext) px-4 py-3" id="two-factor" asp-page="./TwoFactorAuthentication">
                    <i class="bi bi-shield-lock me-2"></i>Xác thực hai yếu tố
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext) px-4 py-3" id="personal-data" asp-page="./PersonalData">
                    <i class="bi bi-file-person me-2"></i>Dữ liệu cá nhân
                </a>
            </li>
        </ul>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
}

<style>
    .nav-pills .nav-link {
        color: #64748b;
        border-radius: 0;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
    }
    
    .nav-pills .nav-link:hover {
        background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
        color: #83a4d4;
        border-left-color: #4fc3f7;
        transform: translateX(5px);
    }
    
    .nav-pills .nav-link.active {
        background: linear-gradient(135deg, #83a4d4 0%, #b6fbff 100%);
        color: white;
        border-left-color: #4fc3f7;
        box-shadow: 0 4px 12px rgba(131, 164, 212, 0.3);
    }
    
    .nav-pills .nav-link i {
        opacity: 0.8;
    }
    
    .nav-pills .nav-link.active i,
    .nav-pills .nav-link:hover i {
        opacity: 1;
    }
</style>
