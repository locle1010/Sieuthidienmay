@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Xóa dữ liệu cá nhân";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="mb-4 fw-bold" style="color: #1e293b;">
    <i class="bi bi-exclamation-triangle me-2" style="color: #ef4444;"></i>@ViewData["Title"]
</h3>

@if (TempData["StatusMessage"] != null)
{
    <partial name="_StatusMessage" model="@TempData["StatusMessage"]" />
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-modern border-0 rounded-4 border-danger" style="border-width: 2px !important;">
            <div class="card-body p-4">
                <div class="alert alert-danger rounded-3 mb-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 2rem;"></i>
                        <div>
                            <h5 class="alert-heading fw-bold">Cảnh báo!</h5>
                            <p class="mb-0">
                                Xóa dữ liệu này sẽ xóa vĩnh viễn tài khoản của bạn và không thể khôi phục được. 
                                Vui lòng cân nhắc kỹ trước khi tiếp tục.
                            </p>
                        </div>
                    </div>
                </div>

                <form id="delete-user" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                    }
                    
                    @if (Model.RequirePassword)
                    {
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" 
                                   aria-required="true" placeholder="Mật khẩu" type="password" />
                            <label asp-for="Input.Password"><i class="bi bi-lock me-2"></i>Nhập mật khẩu để xác nhận</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                    }
                    
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" required id="confirmDelete" />
                        <label class="form-check-label fw-bold" for="confirmDelete">
                            Tôi hiểu rằng hành động này không thể hoàn tác
                        </label>
                    </div>
                    
                    <button class="btn btn-danger px-4 py-2 fw-bold" type="submit" disabled id="deleteButton">
                        <i class="bi bi-trash me-2"></i>Xóa tài khoản vĩnh viễn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('confirmDelete').addEventListener('change', function() {
            document.getElementById('deleteButton').disabled = !this.checked;
        });
    </script>
    <style>
        .form-floating > .form-control:focus ~ label {
            color: #ef4444;
        }
        
        .form-control:focus {
            border-color: #ef4444;
            box-shadow: 0 0 0 0.2rem rgba(239, 68, 68, 0.15);
        }
        
        .form-check-input:checked {
            background-color: #ef4444;
            border-color: #ef4444;
        }
    </style>
}

