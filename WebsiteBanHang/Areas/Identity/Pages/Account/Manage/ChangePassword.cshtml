@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="mb-4 fw-bold" style="color: #1e293b;">
    <i class="bi bi-key me-2" style="color: #83a4d4;"></i>@ViewData["Title"]
</h3>

<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-modern border-0 rounded-4">
            <div class="card-body p-4">
                <form id="change-password-form" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                    }
                    
                    <div class="alert alert-info rounded-3 mb-4">
                        <i class="bi bi-info-circle me-2"></i>
                        Mật khẩu phải có ít nhất 6 ký tự, bao gồm chữ hoa, chữ thường và số.
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" 
                               aria-required="true" placeholder="Mật khẩu hiện tại" type="password" />
                        <label asp-for="Input.OldPassword"><i class="bi bi-lock me-2"></i>Mật khẩu hiện tại</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" 
                               aria-required="true" placeholder="Mật khẩu mới" type="password" />
                        <label asp-for="Input.NewPassword"><i class="bi bi-shield-lock me-2"></i>Mật khẩu mới</label>
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" 
                               aria-required="true" placeholder="Xác nhận mật khẩu mới" type="password" />
                        <label asp-for="Input.ConfirmPassword"><i class="bi bi-shield-check me-2"></i>Xác nhận mật khẩu mới</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary px-4 py-2 fw-bold">
                        <i class="bi bi-check-circle me-2"></i>Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <partial name="_ValidationScriptsPartial" />
    <style>
        .form-floating > .form-control:focus ~ label {
            color: #83a4d4;
        }
        
        .form-control:focus {
            border-color: #83a4d4;
            box-shadow: 0 0 0 0.2rem rgba(131, 164, 212, 0.15);
        }
        
        /* Ẩn validation summary khi không có lỗi */
        .validation-summary-valid {
            display: none !important;
        }
    </style>
}
