@using Web_dienmay.Models
@model IEnumerable<Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var currentPage = (int)ViewData["CurrentPage"];
    var totalPages = (int)ViewData["TotalPages"];
    var currentFilter = ViewData["CurrentFilter"] as string;
    var currentStatus = ViewData["CurrentStatus"] as string;
    var orderStatuses = ViewData["OrderStatuses"] as List<string>;
}

<div class="container-fluid">
    <h1 class="mt-4 text-black">Quản lý đơn hàng</h1>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            Danh sách đơn hàng
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <form asp-action="Index" method="get" class="d-flex">
                        <div class="input-group">
                            <input type="text" name="searchString" value="@currentFilter" class="form-control" placeholder="Tìm kiếm theo mã, tên khách hàng, email...">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Reset</a>
                    </form>
                </div>
                <div class="col-md-6">
                    <form asp-action="Index" method="get" class="d-flex justify-content-end">
                        <div class="input-group" style="max-width: 300px;">
                            <label class="input-group-text">Trạng thái</label>
                            <select name="orderStatus" class="form-select" onchange="this.form.submit()">
                                @foreach (var status in orderStatuses)
                                {
                                    <option value="@status" selected="@(status == currentStatus)">@status</option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn hàng</th>
                            <th>Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var order in Model)
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div>@order.ApplicationUser.FullName</div>
                                        <small class="text-muted">@order.ApplicationUser.Email</small>
                                    </td>
                                    <td class="text-end">@order.TotalPrice.ToString("N0") ₫</td>
                                    <td>
                                        @{
                                            var badgeClass = order.OrderStatus switch
                                            {
                                                "Đang xử lý" => "bg-warning",
                                                "Đã xác nhận" => "bg-info",
                                                "Đang giao hàng" => "bg-primary",
                                                "Đã giao hàng" => "bg-success",
                                                "Đã hủy" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@order.OrderStatus</span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-primary">
                                                <i class="bi bi-info-circle"></i> Chi tiết
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i> Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-3">Không có đơn hàng nào phù hợp với tiêu chí tìm kiếm</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="1"
                               asp-route-searchString="@currentFilter" asp-route-orderStatus="@currentStatus">Đầu</a>
                        </li>
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)"
                               asp-route-searchString="@currentFilter" asp-route-orderStatus="@currentStatus">Trước</a>
                        </li>

                        @{
                            var startPage = Math.Max(1, currentPage - 2);
                            var endPage = Math.Min(totalPages, startPage + 4);
                            startPage = Math.Max(1, endPage - 4);

                            for (var i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                                       asp-route-searchString="@currentFilter" asp-route-orderStatus="@currentStatus">@i</a>
                                </li>
                            }
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)"
                               asp-route-searchString="@currentFilter" asp-route-orderStatus="@currentStatus">Tiếp</a>
                        </li>
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@totalPages"
                               asp-route-searchString="@currentFilter" asp-route-orderStatus="@currentStatus">Cuối</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
