@using Web_dienmay.Models
@model IEnumerable<Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var searchTerm = ViewBag.SearchTerm as string ?? string.Empty;
    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
}

<div class="container-fluid mt-4">
    <!-- Notification area for messages -->
    <div id="notification-area"></div>

    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="text-black"><i class="bi bi-box-seam"></i> Quản lý sản phẩm</h2>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-end gap-2">
                <a asp-area="Admin" asp-controller="Stock" asp-action="Index" class="btn btn-info">
                    <i class="bi bi-clock-history"></i> Lịch sử kho
                </a>
                <a asp-area="Admin" asp-controller="Stock" asp-action="Import" class="btn btn-warning">
                    <i class="bi bi-box-arrow-in-down"></i> Nhập kho
                </a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Thêm sản phẩm
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <!-- Search Box -->
        <div class="col-md-5 mb-3">
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="search-products" class="form-control"
                       placeholder="Tìm theo mã hoặc tên sản phẩm..." value="@searchTerm">
                <button class="btn btn-outline-secondary" type="button" id="clear-search">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        </div>
        <!-- Category Filter -->
        <div class="col-md-3 mb-3">
            <form method="get" asp-area="Admin" asp-controller="Product" asp-action="Index" id="category-form" class="d-flex">
                <input type="hidden" name="searchTerm" value="@searchTerm" id="category-search-term" />
                <input type="hidden" name="filter" value="@currentFilter" />
                <select name="categoryId" class="form-select" id="category-select">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var item in ViewBag.Categories)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </form>
        </div>
        <!-- Status Filters -->
        <div class="col-md-4 mb-3">
            <div class="d-flex justify-content-end">
                <div class="btn-group" role="group" id="filter-buttons">
                    <a href="javascript:void(0)" data-filter="all" class="btn btn-outline-secondary @(currentFilter == "all" ? "active" : "")">Tất cả</a>
                    <a href="javascript:void(0)" data-filter="available" class="btn btn-outline-success @(currentFilter == "available" ? "active" : "")">Đang bật</a>
                    <a href="javascript:void(0)" data-filter="unavailable" class="btn btn-outline-danger @(currentFilter == "unavailable" ? "active" : "")">Đang tắt</a>
                    <a href="javascript:void(0)" data-filter="outofstock" class="btn btn-outline-warning @(currentFilter == "outofstock" ? "active" : "")">Hết hàng</a>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover" id="product-table">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">Hình ảnh</th>
                    <th style="width: 28%;">Tên sản phẩm</th>
                    <th style="width: 12%;">Giá</th>
                    <th style="width: 12%;">Danh mục</th>
                    <th class="text-center" style="width: 12%;">Trạng thái</th>
                    <th class="text-center" style="width: 10%;">Tồn kho</th>
                    <th class="text-center" style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr class="@(product.IsAvailable ? "" : "table-secondary") product-row"
                        data-id="@product.Id" data-name="@product.Name.ToLower()">
                        <td>
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <i class="bi bi-image text-secondary"></i>
                                </div>
                            }
                        </td>
                        <td class="text-truncate-container">
                            <a href="/Product/Display/@product.Id" target="_blank" class="text-decoration-none fw-bold product-name">@product.Name</a>
                            <span class="d-block text-muted small">ID: @product.Id</span>
                        </td>
                        <td class="align-middle">@product.Price.ToString("N0") ₫</td>
                        <td class="align-middle">@product.Category?.Name</td>
                        <td class="text-center align-middle">
                            <div class="form-check form-switch d-inline-block">
                                <input class="form-check-input toggle-status" type="checkbox" id="status-@product.Id"
                                       data-id="@product.Id" @(product.IsAvailable ? "checked" : "")>
                                <label class="form-check-label" for="status-@product.Id">
                                    @if (product.IsAvailable)
                                    {
                                        <span class="badge bg-success">Đang bật</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Đang tắt</span>
                                    }
                                </label>
                            </div>
                        </td>
                        <td class="text-center align-middle">
                            <div class="d-flex flex-column align-items-center gap-1">
                                <span class="fs-5 fw-bold text-primary">@product.StockQuantity</span>
                                @if (product.StockQuantity <= 0)
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                                else if (product.StockQuantity <= 5)
                                {
                                    <span class="badge bg-warning text-dark">Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Còn hàng</span>
                                }
                            </div>
                        </td>
                        <td class="text-center align-middle">
                            <div class="d-flex flex-column gap-1">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id"
                                       class="btn btn-primary" title="Sửa sản phẩm">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id"
                                       class="btn btn-danger" title="Xóa sản phẩm">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </div>
                                <a asp-area="Admin" asp-controller="Stock" asp-action="Index" asp-route-productId="@product.Id"
                                   class="btn btn-sm btn-outline-info" title="Xem lịch sử nhập xuất kho">
                                    <i class="bi bi-clock-history"></i> Lịch sử kho
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div id="no-products-message" class="alert alert-info text-center my-4 @(Model.Any() ? "d-none" : "")">
        <i class="bi bi-search fs-3 d-block mb-3"></i>
        <h5>Không tìm thấy sản phẩm</h5>
        <p>Không có sản phẩm nào phù hợp với tiêu chí tìm kiếm của bạn.</p>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Show a notification message
            function showNotification(message, isSuccess = true) {
                $("#notification-area").empty();

                const alertClass = isSuccess ? 'alert-success' : 'alert-danger';
                const icon = isSuccess ? 'check-circle' : 'exclamation-triangle';
                const notification = `
                    <div class="alert ${alertClass} alert-dismissible fade show">
                        <i class="bi bi-${icon}"></i> ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;

                $("#notification-area").html(notification);
                setTimeout(() => {
                    $(".alert").alert('close');
                }, 5000);

                // Scroll to notification
                $('html, body').animate({
                    scrollTop: $("#notification-area").offset().top - 100
                }, 300);
            }

            // Initialize search functionality
            let debounceTimer;
            $("#search-products").on("input", function() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function() {
                    const searchText = $("#search-products").val().toLowerCase();
                    filterProducts(searchText);
                }, 300);
            });

            // Clear search
            $("#clear-search").on("click", function() {
                $("#search-products").val('');
                filterProducts('');
            });

            // Handle client-side filtering
            function filterProducts(searchText) {
                let visibleProducts = 0;
                $(".product-row").each(function() {
                    const row = $(this);
                    const productId = row.data("id").toString();
                    const productName = row.data("name");

                    if (searchText === '' ||
                        productId.includes(searchText) ||
                        productName.includes(searchText)) {
                        row.removeClass("d-none");
                        visibleProducts++;
                    } else {
                        row.addClass("d-none");
                    }
                });

                if (visibleProducts === 0) {
                    $("#no-products-message").removeClass("d-none");
                } else {
                    $("#no-products-message").addClass("d-none");
                }
            }

            // Category filter change
            $("#category-select").on("change", function() {
                $("#category-search-term").val($("#search-products").val());
                $("#category-form").submit();
            });

            // Handle filter buttons
            $("#filter-buttons a").on("click", function() {
                const filter = $(this).data("filter");
                const currentCategoryId = $("#category-select").val();
                const searchTerm = $("#search-products").val();

                window.location.href = `/Admin/Product/Index?categoryId=${currentCategoryId}&filter=${filter}&searchTerm=${encodeURIComponent(searchTerm)}`;
            });

            // Toggle product availability
            $('.toggle-status').change(function() {
                const productId = $(this).data('id');
                const isChecked = $(this).prop('checked');
                const label = $(this).next('label');
                const row = $(this).closest('tr');
                const checkbox = $(this);

                $.ajax({
                    url: '/Admin/Product/ToggleAvailability',
                    type: 'POST',
                    data: {
                        id: productId,
                        isAvailable: isChecked
                    },
                    success: function(response) {
                        if (response.success) {
                            if (isChecked) {
                                label.html('<span class="badge bg-success">Đang bật</span>');
                                row.removeClass('table-secondary');
                            } else {
                                label.html('<span class="badge bg-danger">Đang tắt</span>');
                                row.addClass('table-secondary');
                            }

                            showNotification('✓ Đã cập nhật trạng thái sản phẩm thành công!');
                        } else {
                            showNotification('✗ Có lỗi xảy ra khi cập nhật trạng thái sản phẩm.', false);
                            checkbox.prop('checked', !isChecked);
                        }
                    },
                    error: function() {
                        showNotification('✗ Có lỗi xảy ra khi cập nhật trạng thái sản phẩm.', false);
                        checkbox.prop('checked', !isChecked);
                    }
                });
            });
        });
    </script>
    <style>
        .text-truncate-container {
            max-width: 100%;
        }

        .product-name {
            display: block;
            white-space: normal;
            word-wrap: break-word;
            max-width: 100%;
            line-height: 1.3;
        }

        #product-table th, #product-table td {
            vertical-align: middle;
        }

        #product-table th {
            background-color: #212529;
            color: white;
        }

        @@media (max-width: 992px) {
            .product-name {
                font-size: 0.9rem;
            }

            #product-table .btn-sm {
                padding: 0.25rem 0.4rem;
                font-size: 0.75rem;
            }
        }
    </style>
}