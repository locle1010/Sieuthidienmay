<!-- WebsiteBanHang/Areas/Admin/Views/User/Details.cshtml -->
@model Web_dienmay.ViewModels.UserDetailsViewModel

@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="text-success">Chi tiết người dùng</h2>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Tên đầy đủ:</div>
                <div class="col-md-9">@Model.FullName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Tên đăng nhập:</div>
                <div class="col-md-9">@Model.UserName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Email:</div>
                <div class="col-md-9">@Model.Email</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Số điện thoại:</div>
                <div class="col-md-9">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Địa chỉ:</div>
                <div class="col-md-9">@(string.IsNullOrEmpty(Model.Address) ? "Chưa cập nhật" : Model.Address)</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Tuổi:</div>
                <div class="col-md-9">@(string.IsNullOrEmpty(Model.Age) ? "Chưa cập nhật" : Model.Age)</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">Vai trò:</div>
                <div class="col-md-9">
                    @foreach (var role in Model.Roles)
                    {
                        <span class="badge bg-primary me-1">@role</span>
                    }
                </div>
            </div>
        </div>
        <div class="card-footer">
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                <div>
                    <a asp-action="Manage" asp-route-userId="@Model.UserId" class="btn btn-primary">Quản lý vai trò</a>
                    <a asp-action="Delete" asp-route-userId="@Model.UserId" class="btn btn-danger">Xóa</a>
                </div>
            </div>
        </div>
    </div>
</div>
