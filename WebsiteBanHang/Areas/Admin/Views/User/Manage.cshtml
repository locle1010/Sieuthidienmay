<!-- WebsiteBanHang/Areas/Admin/Views/User/Manage.cshtml -->
@model List<Web_dienmay.ViewModels.ManageUserRolesViewModel>

@{
    ViewData["Title"] = "Quản lý vai trò";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="text-success">Quản lý vai trò</h2>
            <h5 class="text-muted">Người dùng: @ViewBag.FullName (@ViewBag.UserName)</h5>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <div class="card-body">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <div class="form-check mb-2">
                            <input type="hidden" asp-for="@Model[i].RoleId" />
                            <input type="hidden" asp-for="@Model[i].RoleName" />
                            <input asp-for="@Model[i].Selected" class="form-check-input" />
                            <label class="form-check-label" asp-for="@Model[i].Selected">
                                @Model[i].RoleName
                            </label>
                        </div>
                    }
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <input type="submit" value="Cập nhật" class="btn btn-success" />
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
