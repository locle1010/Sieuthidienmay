<style>
    /* Styling for headquarters badge */
    .headquarters-badge {
        display: inline-block;
        background-color: var(--bright-orange);
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 500;
        font-size: 0.9rem;
    }

    /* Styling for showroom cards */
    .showroom-card {
        transition: all 0.3s ease;
    }

        .showroom-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

    /* Button styling */
    .btn-outline-teal {
        color: var(--teal);
        border-color: var(--teal);
    }

        .btn-outline-teal:hover {
            background-color: var(--teal);
            color: white;
        }
</style>
