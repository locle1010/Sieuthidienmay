@{
    ViewData["Title"] = "Hệ thống Showroom";
}

<div class="container py-5">
    <!-- Banner section -->
    <div class="card border-0 shadow-lg mb-5">
        <div class="row g-0">
            <div class="col-md-6">
                <div class="card-body p-4 p-md-5 d-flex flex-column justify-content-center h-100">
                    <h1 class="display-5 fw-bold mb-4" style="color: var(--teal);">Hệ thống Showroom</h1>
                    <p class="lead mb-4">
                        Siêu thị Điện Máy hiện có 8 chi nhánh và 1 trụ sở chính trên toàn quốc, sẵn sàng phục vụ khách hàng ở mọi khu vực.
                    </p>
                    <p class="mb-0">
                        Mỗi showroom của chúng tôi đều được thiết kế hiện đại, rộng rãi và trưng bày đầy đủ các sản phẩm mới nhất để bạn có trải nghiệm mua sắm tốt nhất.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div style="height: 400px; background: linear-gradient(135deg, var(--teal) 0%, #005a70 100%); overflow: hidden;">
                    <div class="d-flex align-items-center justify-content-center h-100">
                        <i class="bi bi-shop text-white" style="font-size: 8rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Trụ sở chính -->
