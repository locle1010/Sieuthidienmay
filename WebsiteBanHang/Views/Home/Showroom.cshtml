                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.634267509162!2d105.8406103154186!3d21.006998593986007!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ac76bb68b4c3%3A0xc8e701bc9ffbd2ab!2zSOG7kyBIb8OgbiBLaeG6v20!5e0!3m2!1svi!2s!4v1658988889015!5m2!1svi!2s"
                                style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="p-4 p-md-5 d-flex flex-column h-100 justify-content-center">
                        <div class="headquarters-badge">Trụ sở chính</div>
                        <h3 class="mt-3 mb-3" style="color: var(--teal);">Trụ sở chính - Bình Nguyên Vô Tận</h3>
                        <div class="d-flex mb-3">
                            <i class="bi bi-geo-alt me-3" style="color: var(--bright-orange); font-size: 1.5rem;"></i>
                            <p class="mb-0">Trụ ngoài, đường giữa, Quận Bình Nguyên Vô Tận, Thành phố Liên Quân</p>
                        </div>
                        <div class="d-flex mb-3">
                            <i class="bi bi-telephone me-3" style="color: var(--bright-orange); font-size: 1.5rem;"></i>
                            <p class="mb-0">1234 1234</p>
                        </div>
                        <div class="d-flex mb-4">
                            <i class="bi bi-clock me-3" style="color: var(--bright-orange); font-size: 1.5rem;"></i>
                            <p class="mb-0">08:00 - 21:00 (Tất cả các ngày trong tuần)</p>
                        </div>
                        <a href="https://maps.google.com" target="_blank" class="btn" style="background-color: var(--teal); color: white;">
                            <i class="bi bi-geo-alt me-2"></i>Chỉ đường
                        </a>
                    </div>
                </div>
            </div>
        </div>
