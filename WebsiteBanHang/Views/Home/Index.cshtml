@{
    ViewData["Title"] = "Trang chủ";

    var bestSellingProducts = ViewBag.BestSellingProducts as List<Product>;
    var randomProducts = ViewBag.RandomProducts as List<Product>;
}

<!-- Hero Banner with Best Selling Products Carousel -->
<div class="hero-section mb-5">
    <div class="container">
        <!-- Full-width Hero Banner -->
        <div class="card border-0 shadow-lg overflow-hidden mb-5">
            <div class="card-body p-0">
                <div id="bestSellingCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < bestSellingProducts.Count; i++)
                        {
                            var product = bestSellingProducts[i];
                            if (product.IsAvailable && product.StockQuantity > 0)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="text-decoration-none">
                                        <div class="row g-0">
                                            <div class="col-md-6">
                                                <div class="hero-image-container">
                                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                                    {
                                                        <img src="@product.ImageUrl" class="img-fluid" alt="@product.Name">
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light d-flex align-items-center justify-content-center h-100">
                                                            <i class="bi bi-image" style="font-size: 5rem; color: var(--teal);"></i>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="p-4 p-md-5 d-flex flex-column justify-content-center h-100">
                                                    <span class="badge mb-2" style="background-color: var(--teal); width: fit-content;">
                                                        @product.Category?.Name
                                                    </span>
                                                    <h2 style="color: var(--teal);">@product.Name</h2>
                                                    <p class="text-muted my-3" style="display: -webkit-box; -webkit-line-clamp: 3;
                                                          -webkit-box-orient: vertical; overflow: hidden;">
                                                        @product.Description
                                                    </p>
                                                    <h3 style="color: var(--bright-orange);" class="mb-3">@product.Price.ToString("N0") ₫</h3>

                                                    <!-- Đánh giá sao -->
                                                    @if (product.RatingCount > 0)
                                                    {
                                                        <div class="product-rating mb-2">
                                                            <div class="rating-stars">
                                                                @for (int i = 1; i <= 5; i++)
                                                                {
                                                                    if (i <= Math.Round(product.AverageRating))
                                                                    {
                                                                        <i class="bi bi-star-fill text-warning"></i>
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="bi bi-star text-warning"></i>
                                                                    }
                                                                }
                                                            </div>
                                                            <span class="text-muted ms-1">(@product.RatingCount đánh giá)</span>
                                                        </div>
                                                    }
                                                    @if (product.StockQuantity <= 5)
                                                    {
                                                        <span class="badge" style="background-color: var(--burnt-orange); width: fit-content;">
                                                            Còn @product.StockQuantity sản phẩm
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success" style="width: fit-content;">
                                                            Còn hàng
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                    </div>

                    <!-- Carousel indicators overlaid on the bottom of the carousel -->
                    <div class="carousel-indicators">
                        @{
                            var activeProductCount = 0;
                            for (int i = 0; i < bestSellingProducts.Count; i++)
                            {
                                if (bestSellingProducts[i].IsAvailable && bestSellingProducts[i].StockQuantity > 0)
                                {
                                    <button type="button" data-bs-target="#bestSellingCarousel" data-bs-slide-to="@activeProductCount"
                                            class="@(activeProductCount == 0 ? "active" : "")" aria-current="@(activeProductCount == 0 ? "true" : "false")"
                                            aria-label="Slide @(activeProductCount+1)"></button>
                                    activeProductCount++;
                                }
                            }
                        }
                    </div>

                    <!-- Carousel controls overlaid on the sides -->
                    <button class="carousel-control-prev" type="button" data-bs-target="#bestSellingCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#bestSellingCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Featured Products Section -->
        <div class="card border-0 shadow-sm mb-5">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0" style="color: var(--teal);">
                        <i class="bi bi-stars" style="color: var(--bright-orange);"></i> Sản phẩm đặc sắc
                    </h4>
                    <a asp-controller="Product" asp-action="Index" class="text-decoration-none" style="color: var(--teal);">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                    @foreach (var product in randomProducts)
                    {
                        if (product.IsAvailable && product.StockQuantity > 0)
                        {
                            <div class="col">
                                <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="text-decoration-none">
                                    <div class="card h-100 border-0 shadow-sm hover-shadow">
                                        <div class="position-relative">
                                            <!-- Product Category Badge -->
                                            <span class="position-absolute top-0 start-0 m-2 badge rounded-pill"
                                                  style="background-color: var(--teal);">
                                                @product.Category?.Name
                                            </span>

                                            <!-- Stock Status Badge -->
                                            @if (product.StockQuantity <= 5)
                                            {
                                                <span class="position-absolute top-0 end-0 m-2 badge rounded-pill"
                                                      style="background-color: var(--burnt-orange);">
                                                    Còn @product.StockQuantity sản phẩm
                                                </span>
                                            }

                                            <!-- Product Image -->
                                            <div style="height: 200px; overflow: hidden;">
                                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                                {
                                                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                                                         style="width: 100%; height: 200px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="bg-light d-flex align-items-center justify-content-center"
                                                         style="height: 200px;">
                                                        <i class="bi bi-image" style="font-size: 3rem; color: var(--teal);"></i>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="card-body d-flex flex-column">
                                            <!-- Product Name -->
                                            <h5 class="card-title" style="height: 48px; overflow: hidden; display: -webkit-box;
                                                       -webkit-line-clamp: 2; -webkit-box-orient: vertical; color: var(--teal);">
                                                @product.Name
                                            </h5>

                                            <!-- Product Description -->
                                            <p class="card-text text-muted" style="height: 72px; overflow: hidden; display: -webkit-box;
                                    -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                                @product.Description
                                            </p>

                                            <!-- Đánh giá sao -->
                                            @if (product.RatingCount > 0)
                                            {
                                                <div class="product-rating mb-2">
                                                    <div class="rating-stars">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (i <= Math.Round(product.AverageRating))
                                                            {
                                                                <i class="bi bi-star-fill text-warning"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-star text-warning"></i>
                                                            }
                                                        }
                                                    </div>
                                                    <small class="text-muted ms-1">(@product.RatingCount)</small>
                                                </div>
                                            }

                                            <!-- Product Price -->
                                            <h5 class="card-text mt-auto" style="color: var(--bright-orange);">@product.Price.ToString("N0") ₫</h5>

                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Browse All Products Section -->
<div class="container mb-5">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <h3 class="mb-4" style="color: var(--teal);">Khám phá tất cả sản phẩm</h3>
                    <p class="text-muted mb-4">
                        Chúng tôi cung cấp đa dạng các sản phẩm điện máy chất lượng cao với đầy đủ phụ kiện và chế độ bảo hành.
                        Hãy xem toàn bộ danh mục sản phẩm của chúng tôi ngay hôm nay!
                    </p>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-lg px-5 py-3"
                       style="background-color: var(--bright-orange); color: white;">
                        <i class="bi bi-grid-3x3-gap me-2"></i> Xem tất cả sản phẩm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

    /* Hero banner styling */
    .hero-section {
        padding: 30px 0;
    }

    .hero-image-container {
        height: 450px;
        overflow: hidden;
    }

        .hero-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Enhanced carousel controls */
    #bestSellingCarousel {
        position: relative;
    }

    .carousel-indicators {
        position: absolute;
        bottom: 20px;
        margin: 0;
        left: 0;
        right: 0;
        z-index: 15;
    }

        .carousel-indicators button {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin: 0 5px;
            background-color: var(--teal);
        }

    .carousel-control-prev, .carousel-control-next {
        width: auto;
        padding: 0 15px;
        z-index: 20;
    }

    .carousel-control-prev-icon, .carousel-control-next-icon {
        filter: invert(36%) sepia(51%) saturate(1287%) hue-rotate(155deg) brightness(93%) contrast(101%);
        border-radius: 50%;
        padding: 25px;
    }

    .carousel-item {
        transition: transform 0.6s ease-in-out;
    }

    /* Fix text color for linked cards */
    a .card .card-body h5 {
        color: var(--teal);
    }

    a .card .card-body p {
        color: #6c757d;
    }

    a .card .card-body h5.card-text {
        color: var(--bright-orange);
    }

    a:hover {
        text-decoration: none;
    }

    /* Make the shadow more prominent */
    .shadow-lg {
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 767.98px) {
        .hero-image-container

    {
        height: 300px;
    }

    }
    /* Star rating styles */
    .rating-stars {
        display: inline-flex;
    }

    .product-rating {
        display: flex;
        align-items: center;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize carousel with 5-second interval
            $('#bestSellingCarousel').carousel({
                interval: 5000
            });

            // Initialize hover effects
            $(".hover-shadow").hover(
                function() { $(this).css("transform", "translateY(-5px)"); },
                function() { $(this).css("transform", ""); }
            );
        });
    </script>
}
